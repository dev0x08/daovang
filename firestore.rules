rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    match /users/{uid} { allow read: if signedIn(); allow create, update: if signedIn() && request.auth.uid == uid; }
    match /rooms/{roomId} { allow read, create, update, delete: if signedIn(); }
  }
}
